{
  "manifest_version": 3,
  "name": "UEDA EX 5.0",
  "version": "5.1.0",
  "description": "Extensão UEDA EX 5.0 — assistente com marca personalizada.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": { "default_title": "UEDA EX 5.0" },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["widget.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    { "resources": ["logo.png", "config.json"], "matches": ["<all_urls>"] }
  ],
  "icons": { "48": "logo.png", "128": "logo.png" }
}
