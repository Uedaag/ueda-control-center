{
  "manifest_version": 3,
  "name": "UEDA EX",
  "version": "1.0",
  "description": "ilimitado",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://api.lovable.dev/*",
    "https://uedaagency.lovable.app/*",
    "https://*.lovable.dev/*",
    "https://*.lovable.app/*",
    "https://keqgzvcahsvseowfowwu.supabase.co/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png",
      "64": "icon.png",
      "128": "icon.png",
      "256": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "64": "icon.png",
    "128": "icon.png",
    "256": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["https://lovable.dev/*", "https://*.lovable.dev/*", "https://*.lovable.app/*", "https://uedaagency.lovable.app/*"],
      "css": ["widget.css"],
      "js": ["widget.js"],
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icon.png"],
      "matches": ["https://lovable.dev/*", "https://*.lovable.dev/*", "https://*.lovable.app/*", "https://uedaagency.lovable.app/*"]
    }
  ]
}
